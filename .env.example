# Google Gemini (optional, vision-capable via OpenAI-compatible endpoint)
# Get your API key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza-your-key-here
# GEMINI_MODEL=gemini-2.5-flash   # default; pro: gemini-2.5-pro, flash-next: gemini-3-flash-preview
# GEMINI_OCR_MODEL=gemini-2.5-flash  # modelo usado para OCR automatico (quando provider principal nao tem visao)

# DeepSeek (default provider)
DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-pro   # default; flash: deepseek-v4-flash; vision: web-only beta (chat.deepseek.com), API nao suporta

# OpenAI (optional)
# OPENAI_API_KEY=sk-your-key-here

# Anthropic / Claude (optional)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-6   # default; opus: claude-opus-4-7, fast: claude-haiku-4-5-20251001

# Grok / xAI (optional)
# GROK_API_KEY=xai-your-key-here

# Ollama / local models (no API key needed)
# OLLAMA_API_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5-coder:14b
# OLLAMA_GEMMA_12B_MODEL=gemma3:12b
# OLLAMA_GEMMA_27B_MODEL=gemma3:27b

# Default provider: deepseek, openai, anthropic, grok, ollama, google, gemma-12b, gemma-27b
# ALPHA_PROVIDER=deepseek

# Default named agent profile (loads agents/<name>/agent.yaml)
# ALPHA_AGENT=default

# Agent workspace (defaults to current directory)
# AGENT_WORKSPACE=/home/user/projects

# Browser tool policy
# ALPHA_BROWSER_ALLOWLIST=example.com,docs.python.org
# ALPHA_BROWSER_BLOCKLIST=evil.com
# ALPHA_BROWSER_REQUIRE_ALLOWLIST=1   # fail-closed when allowlist is empty

# Apify (scraping via apify_run_actor / apify_search_actors)
# APIFY_API_TOKEN=apify_api_xxx

# Disable ANSI colors in terminal output
# NO_COLOR=1

# Sub-agent (#D007): politica de bloqueio quando sub-agent roda sem
# approval callback (modo daemon / non-interactive).
# - "strict" (default): bloqueia tools destrutivas — so usa safe + git ro.
# - "relaxed": deixa o sub-agent usar tudo exceto delegate_* (anti-recursao).
#   So use se voce confia totalmente no prompt do parent.
# ALPHA_SUBAGENT_POLICY=strict
# Tools extras a bloquear (alem do default). Comma-separated.
# ALPHA_SUBAGENT_EXTRA_BLOCK=write_file,edit_file
# Tools a permitir mesmo se estiverem na blocklist default.
# ALPHA_SUBAGENT_ALLOW=execute_shell
